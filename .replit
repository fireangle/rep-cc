modules = ["go-1.25"]

run = "cd /home/runner/workspace/artifacts/go-proxy && go build -o proxy . && PORT=8000 ./proxy"

[deployment]
router = "application"
deploymentTarget = "autoscale"
run = ["sh", "-c", "cd /home/runner/workspace/artifacts/go-proxy && go build -o proxy . && PORT=8000 ./proxy"]

[workflows]

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[[ports]]
localPort = 8000
externalPort = 80
