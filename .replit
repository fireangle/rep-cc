modules = ["go-1.25"]

[deployment]
router = "application"
deploymentTarget = "autoscale"
run = ["sh", "-c", "cd /home/runner/workspace/artifacts/go-proxy && exec ./proxy"]
build = ["sh", "-c", "cd /home/runner/workspace/artifacts/go-proxy && go build -o proxy ."]

[workflows]

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[[ports]]
localPort = 8000
externalPort = 80
